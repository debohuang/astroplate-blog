---
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { render } from "astro:content";
import PageHeader from "@/partials/PageHeader.astro";

const homepageContent = await getListPage("homepage", "-index");
const { Content } = await render(homepageContent);
const { banner, features } = homepageContent.data;
---

<Base
  title="Free Online Image Merge & Text to Image Tools"
  meta_title="Image Merge Tools - Combine Images & Add Text Online for Free"
  description="Free online image merge and text to image tools. Merge images horizontally, vertically, in grids. Add text overlays to photos instantly. No registration needed."
>
  <!-- Hero Banner -->
  <section class="section pt-20 pb-16">
    <div class="container">
      <div class="row items-center">
        <div class="lg:col-6 mb-8 lg:mb-0">
          <h1 class="mb-6 text-h2 lg:text-h1">
            {banner.title}
          </h1>
          <p class="mb-8 text-lg text-text dark:text-darkmode-text">
            {banner.content}
          </p>
          {
            banner.button.enable && (
              <a href={banner.button.link} class="btn btn-primary">
                {banner.button.label}
              </a>
            )
          }
        </div>
        <div class="lg:col-6">
          {
            banner.image && (
              <img
                src={banner.image}
                alt="Image Merge Tools"
                class="w-full rounded-lg shadow-lg"
              />
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="section bg-light dark:bg-darkmode-light">
    <div class="container">
      {
        features.map((feature: any, index: number) => (
          <div class={`row items-center mb-20 last:mb-0 ${index % 2 === 1 ? 'flex-row-reverse' : ''}`}>
            <div class="lg:col-6 mb-8 lg:mb-0">
              {feature.image && (
                <img
                  src={feature.image}
                  alt={feature.title}
                  class="w-full rounded-lg shadow-lg"
                />
              )}
            </div>
            <div class={`lg:col-6 ${index % 2 === 1 ? 'lg:pr-12' : 'lg:pl-12'}`}>
              <h2 class="mb-4 text-h3">{feature.title}</h2>
              <p class="mb-6 text-text dark:text-darkmode-text">
                {feature.content}
              </p>
              <ul class="space-y-3 mb-8">
                {feature.bulletpoints.map((point: string) => (
                  <li class="flex items-start gap-3">
                    <span class="text-primary dark:text-darkmode-primary mt-1">✓</span>
                    <span set:html={point} />
                  </li>
                ))}
              </ul>
              {feature.button.enable && (
                <a href={feature.button.link} class="btn btn-primary">
                  {feature.button.label}
                </a>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-8 text-center">
          <h2 class="mb-6">Ready to Create Amazing Graphics?</h2>
          <p class="mb-8 text-lg">
            Join thousands of creators, marketers, and photographers using Image Merge Tools daily to create professional graphics.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/tools/image-merge" class="btn btn-primary">
              Merge Images Now
            </a>
            <a href="/tools/text-to-image" class="btn btn-outline">
              Add Text to Image
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="section bg-gradient">
    <div class="container">
      <div class="row justify-center text-center">
        <div class="md:col-4 mb-8 md:mb-0">
          <div class="text-4xl font-bold text-white mb-2">100%</div>
          <p class="text-white/80">Completely Free</p>
        </div>
        <div class="md:col-4 mb-8 md:mb-0">
          <div class="text-4xl font-bold text-white mb-2">6</div>
          <p class="text-white/80">Languages Supported</p>
        </div>
        <div class="md:col-4">
          <div class="text-4xl font-bold text-white mb-2">2</div>
          <p class="text-white/80">Powerful Tools</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Preview Section -->
  <section class="section">
    <div class="container">
      <div class="row justify-center mb-12 text-center">
        <div class="lg:col-8">
          <h2 class="mb-4">Common Questions</h2>
          <p class="text-lg">Everything you need to know about our tools</p>
        </div>
      </div>

      <div class="row">
        <div class="md:col-6 lg:col-4 mb-8">
          <div class="rounded-lg border border-border p-6 dark:border-darkmode-border">
            <h3 class="mb-3 font-semibold">Is it really free?</h3>
            <p class="text-sm text-text dark:text-darkmode-text">
              Yes! Completely free with no registration, no hidden fees, and no premium version.
            </p>
          </div>
        </div>

        <div class="md:col-6 lg:col-4 mb-8">
          <div class="rounded-lg border border-border p-6 dark:border-darkmode-border">
            <h3 class="mb-3 font-semibold">Is my data private?</h3>
            <p class="text-sm text-text dark:text-darkmode-text">
              Your images are never stored. Processing is instant and secure with automatic deletion.
            </p>
          </div>
        </div>

        <div class="md:col-6 lg:col-4 mb-8">
          <div class="rounded-lg border border-border p-6 dark:border-darkmode-border">
            <h3 class="mb-3 font-semibold">How fast is it?</h3>
            <p class="text-sm text-text dark:text-darkmode-text">
              Most image processing completes within 1-3 seconds, depending on file size.
            </p>
          </div>
        </div>

        <div class="md:col-6 lg:col-4 mb-8">
          <div class="rounded-lg border border-border p-6 dark:border-darkmode-border">
            <h3 class="mb-3 font-semibold">What formats are supported?</h3>
            <p class="text-sm text-text dark:text-darkmode-text">
              We support JPG, PNG, WebP, GIF for input and PNG, JPG, WebP for output.
            </p>
          </div>
        </div>

        <div class="md:col-6 lg:col-4 mb-8">
          <div class="rounded-lg border border-border p-6 dark:border-darkmode-border">
            <h3 class="mb-3 font-semibold">Any file size limits?</h3>
            <p class="text-sm text-text dark:text-darkmode-text">
              Maximum 10MB per image. Maximum output resolution is 8000x8000px.
            </p>
          </div>
        </div>

        <div class="md:col-6 lg:col-4 mb-8">
          <div class="rounded-lg border border-border p-6 dark:border-darkmode-border">
            <h3 class="mb-3 font-semibold">Do I need to register?</h3>
            <p class="text-sm text-text dark:text-darkmode-text">
              No registration required! Start using our tools immediately.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
          <p>AI processes your file and converts speech to accurate text</p>
        </div>
        <div class="md:col-4 mb-8">
          <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-primary/10 text-primary dark:bg-darkmode-primary/10 dark:text-darkmode-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="mb-2 text-xl">3. Copy</h3>
          <p>Review and copy your transcription with a single click</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Supported Formats -->
  <section class="section-sm">
    <div class="container">
      <div class="row justify-center">
        <div class="lg:col-8 md:col-10 mb-10 text-center">
          <h2 class="mb-4">Supported Formats</h2>
          <p class="text-lg">Works with all popular audio and video file types</p>
        </div>
      </div>
      <div class="row justify-center">
        <div class="md:col-5 mb-8">
          <h3 class="mb-4 text-lg font-semibold">Audio Files</h3>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-text dark:text-darkmode-text">
              <span class="inline-block rounded bg-primary/10 px-2 py-0.5 text-xs font-semibold text-primary dark:bg-darkmode-primary/10 dark:text-darkmode-primary">MP3</span>
              MPEG Audio Layer 3
            </li>
            <li class="flex items-center gap-2 text-text dark:text-darkmode-text">
              <span class="inline-block rounded bg-primary/10 px-2 py-0.5 text-xs font-semibold text-primary dark:bg-darkmode-primary/10 dark:text-darkmode-primary">WAV</span>
              Waveform Audio
            </li>
            <li class="flex items-center gap-2 text-text dark:text-darkmode-text">
              <span class="inline-block rounded bg-primary/10 px-2 py-0.5 text-xs font-semibold text-primary dark:bg-darkmode-primary/10 dark:text-darkmode-primary">OGG</span>
              Ogg Vorbis
            </li>
            <li class="flex items-center gap-2 text-text dark:text-darkmode-text">
              <span class="inline-block rounded bg-primary/10 px-2 py-0.5 text-xs font-semibold text-primary dark:bg-darkmode-primary/10 dark:text-darkmode-primary">FLAC</span>
              Free Lossless Audio
            </li>
            <li class="flex items-center gap-2 text-text dark:text-darkmode-text">
              <span class="inline-block rounded bg-primary/10 px-2 py-0.5 text-xs font-semibold text-primary dark:bg-darkmode-primary/10 dark:text-darkmode-primary">M4A</span>
              MPEG-4 Audio
            </li>
          </ul>
        </div>
        <div class="md:col-5 mb-8">
          <h3 class="mb-4 text-lg font-semibold">Video Files</h3>
          <ul class="space-y-2">
            <li class="flex items-center gap-2 text-text dark:text-darkmode-text">
              <span class="inline-block rounded bg-primary/10 px-2 py-0.5 text-xs font-semibold text-primary dark:bg-darkmode-primary/10 dark:text-darkmode-primary">MP4</span>
              MPEG-4 Video
            </li>
            <li class="flex items-center gap-2 text-text dark:text-darkmode-text">
              <span class="inline-block rounded bg-primary/10 px-2 py-0.5 text-xs font-semibold text-primary dark:bg-darkmode-primary/10 dark:text-darkmode-primary">WebM</span>
              Web Media
            </li>
            <li class="flex items-center gap-2 text-text dark:text-darkmode-text">
              <span class="inline-block rounded bg-primary/10 px-2 py-0.5 text-xs font-semibold text-primary dark:bg-darkmode-primary/10 dark:text-darkmode-primary">OGG</span>
              Ogg Video
            </li>
            <li class="flex items-center gap-2 text-text dark:text-darkmode-text">
              <span class="inline-block rounded bg-primary/10 px-2 py-0.5 text-xs font-semibold text-primary dark:bg-darkmode-primary/10 dark:text-darkmode-primary">MPEG</span>
              MPEG Video
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Base>
