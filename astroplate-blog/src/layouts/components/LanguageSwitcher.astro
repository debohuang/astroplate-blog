---
import { translations, type Language } from "@/lib/i18n";

const { className }: { className?: string } = Astro.props;

// Available languages
const languages: { code: Language; name: string; flag: string }[] = [
  { code: 'en', name: 'English', flag: '🇺🇸' },
  { code: 'es', name: 'Español', flag: '🇪🇸' },
  { code: 'zh', name: '中文', flag: '🇨🇳' },
  { code: 'fr', name: 'Français', flag: '🇫🇷' },
  { code: 'de', name: 'Deutsch', flag: '🇩🇪' },
  { code: 'ja', name: '日本語', flag: '🇯🇵' },
];

const currentLanguage = 'en';
---

<div class={`language-switcher relative ${className}`} id="language-switcher-container">
  <button
    class="flex items-center gap-2 px-3 py-1.5 rounded-lg border border-border dark:border-darkmode-border hover:border-primary dark:hover:border-darkmode-primary transition-colors text-sm"
    aria-label="Switch language"
    id="language-button"
  >
    <span id="current-flag">{languages.find(l => l.code === currentLanguage)?.flag || '🇺🇸'}</span>
    <span id="current-code" class="font-medium">{currentLanguage.toUpperCase()}</span>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
  <div
    class="language-dropdown absolute right-0 top-[calc(100%+0.5rem)] w-48 bg-white dark:bg-darkmode-bg border border-border dark:border-darkmode-border rounded-lg shadow-lg opacity-0 invisible transition-all duration-200 z-[9999] pointer-events-none"
    id="language-dropdown"
  >
    <ul class="py-1">
      {languages.map((lang) => (
        <li>
          <button
            class={`w-full px-4 py-2 text-left flex items-center gap-2 hover:bg-light dark:hover:bg-darkmode-light transition-colors ${
              lang.code === currentLanguage ? 'bg-light dark:bg-darkmode-light font-medium' : ''
            }`}
            data-language={lang.code}
          >
            <span>{lang.flag}</span>
            <span>{lang.name}</span>
            {lang.code === currentLanguage && (
              <svg class="w-4 h-4 ml-auto text-primary" fill="currentColor" viewBox="0 0 20 20">
                <path
                  fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd"
                />
              </svg>
            )}
          </button>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .language-switcher {
    position: relative !important;
    z-index: 40 !important;
  }

  .language-dropdown {
    z-index: 50 !important;
  }

  .language-dropdown.active {
    opacity: 1 !important;
    visibility: visible !important;
    pointer-events: auto !important;
  }

  .language-dropdown:not(.active) {
    pointer-events: none !important;
  }
</style>

<script>
  // Language switching functionality
  const supportedLanguages = [
    { code: 'en', name: 'English', flag: '🇺🇸' },
    { code: 'es', name: 'Español', flag: '🇪🇸' },
    { code: 'zh', name: '中文', flag: '🇨🇳' },
    { code: 'fr', name: 'Français', flag: '🇫🇷' },
    { code: 'de', name: 'Deutsch', flag: '🇩🇪' },
    { code: 'ja', name: '日本語', flag: '🇯🇵' },
  ];

  function initializeLanguageSwitcher() {
    const button = document.getElementById('language-button') as HTMLButtonElement;
    const dropdown = document.getElementById('language-dropdown') as HTMLDivElement;
    const currentFlag = document.getElementById('current-flag') as HTMLSpanElement;
    const currentCode = document.getElementById('current-code') as HTMLSpanElement;
    const langButtons = dropdown?.querySelectorAll('[data-language]');

    console.log('Language switcher initialized:', { button, dropdown, currentFlag, currentCode });
    console.log('Language buttons found:', langButtons?.length);

    // Load saved language or default to 'en'
    const savedLanguage = localStorage.getItem('language') || 'en';

    function updateLanguageUI(language: string) {
      const langData = supportedLanguages.find(l => l.code === language);
      if (langData && currentFlag && currentCode) {
        currentFlag.textContent = langData.flag;
        currentCode.textContent = langData.code.toUpperCase();
      }

      // Update active state in dropdown
      langButtons?.forEach((btn) => {
        const btnLang = btn.getAttribute('data-language');
        if (btnLang === language) {
          btn.classList.add('bg-light', 'dark:bg-darkmode-light', 'font-medium');
        } else {
          btn.classList.remove('bg-light', 'dark:bg-darkmode-light', 'font-medium');
        }
      });
    }

    // Update UI
    updateLanguageUI(savedLanguage);

    // Toggle dropdown
    button?.addEventListener('click', (e: Event) => {
      e.stopPropagation();
      console.log('Button clicked, toggling dropdown');
      dropdown?.classList.toggle('active');
      console.log('Dropdown active:', dropdown?.classList.contains('active'));
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', () => {
      dropdown?.classList.remove('active');
    });

    // Handle language selection
    langButtons?.forEach((btn) => {
      btn.addEventListener('click', (e: Event) => {
        e.stopPropagation();
        const target = e.currentTarget as HTMLButtonElement;
        const lang = target.dataset.language;
        if (lang) {
          // Save language
          localStorage.setItem('language', lang);

          // Update UI
          updateLanguageUI(lang);

          // Trigger language change event
          window.dispatchEvent(new CustomEvent('language-change', { detail: { language: lang } }));

          // Close dropdown
          dropdown.classList.remove('active');

          // Reload page to apply language changes
          window.location.reload();
        }
      });
    });
  }

  // Run on initial navigation
  initializeLanguageSwitcher();
  // Run on view transitions navigation
  document.addEventListener('astro:after-swap', initializeLanguageSwitcher);
</script>
